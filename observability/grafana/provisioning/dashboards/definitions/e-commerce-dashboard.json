  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Application Performance Metrics",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Mimir"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Mimir"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_request_duration_seconds_count[1m])) by (service)",
          "legendFormat": "{{service}} requests/sec",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Throughput by Service",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Mimir"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Mimir"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, service))",
          "legendFormat": "{{service}} p95 latency",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "p95 Response Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 4,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Mimir"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_request_duration_seconds_count[1m])) by (status_code)",
          "legendFormat": "HTTP Status {{status_code}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "HTTP Status Code Rate",
      "type": "timeseries"
    }
  ],
